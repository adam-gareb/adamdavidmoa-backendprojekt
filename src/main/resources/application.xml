<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEAN//EN" "http://www.springframework.org/dtd/spring-beans-2.0.dtd">

<beans>

    <!--  We create our dataSource which will create database connections (using Apache DBCP
    connection pool  -->
    <bean id="dataSource" class="org.apache.commons.dbcp2.BasicDataSource" destroy-method="close">
        <property name="driverClassName" value="org.hsqldb.jdbcDriver" />
        <property name="url"
            value="jdbc:hsqldb:file:database.dat;shutdown=true" />
        <property name="username" value="sa" />
        <property name="password" value="" />
    </bean>

    <!-- Entity manager -->
    <bean id="entityManagerFactory"
        class="org.springframework.orm.jpa.LocalContainerEntityManagerFactoryBean">
        <property name="dataSource" ref="dataSource" />
        <property name="packagesToScan" value="se.yrgo.spring.domain" />

        <property name="jpaVendorAdapter">
            <bean class="org.springframework.orm.jpa.vendor.HibernateJpaVendorAdapter">
                <property name="generateDdl" value="true" />
                <property name="showSql" value="true" />
                <property name="databasePlatform" value="org.hibernate.dialect.HSQLDialect" />
            </bean>
        </property>
    </bean>

    <!-- Transactions -->
    <bean id="transactionManager"
        class="org.springframework.orm.jpa.JpaTransactionManager">
        <property name="entityManagerFactory"
            ref="entityManagerFactory" />
    </bean>

    <!--  DAO is in charge of communication with SQL and database - we inject via constructor  -->
    <bean id="userDao" class="se.yrgo.dataaccess.UserDaoJpaImpl">
        <constructor-arg ref="jdbcTemplate" />
    </bean>

    <!-- Creating bean for CustomerManagementServiceProductionImpl -->
    <bean id="customerManagementService"
        class="se.yrgo.services.customers.CustomerManagementServiceProductionImpl">
        <constructor-arg ref="customerDao" />
    </bean>

    <!-- Creating bean for CustomerManagementService  -->
    <bean id="diaryManagementService" class="se.yrgo.services.diary.DiaryManagementServiceMockImpl" />

    <!--  Wiring the two classes to callHandlingService using depencency  -->
    <bean id="callHandlingService" class="se.yrgo.services.calls.CallHandlingServiceImpl">
        <constructor-arg ref="customerManagementService" />
        <constructor-arg ref="diaryManagementService" />
    </bean>

</beans>